# --- LLM provider (Ollama por padrao, igual ao inbox-zero) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
MODEL=llama3.1:8b
# PROVIDER=ollama        # forca Ollama mesmo se OPENAI_API_KEY estiver setado
# OPENAI_API_KEY=        # se setado e PROVIDER != ollama, usa OpenAI cloud

# --- GLPI REST API ---
# URL base terminando em /apirest.php
GLPI_URL=https://seu-glpi.exemplo/apirest.php
GLPI_APP_TOKEN=
GLPI_USER_TOKEN=

# --- Telegram

OPENROUTER_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX